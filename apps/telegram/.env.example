# =====================================================================
#  Telegram app configuration
#
#  Copy this file to ".env" in the same folder, then fill in the values:
#      cp .env.example .env
#
#  Every variable shows what it is, an Example, and any Best practice.
#  The two REQUIRED ones are first, then OPTIONAL ones most-needed first.
# =====================================================================


# REQUIRED  -  Telegram bot token from @BotFather.
# The bot will not start without it. Treat it like a password.
# How to get it: open @BotFather in Telegram, send /newbot (or /mybots for
# an existing one), and copy the token it gives you.
# Example:  BOT_TOKEN="123456789:AAFakeExampleTokenFromBotFather_xxx"
BOT_TOKEN=""


# REQUIRED  -  MySQL/MariaDB connection string.
# Must be the SAME database you created the tables in and seeded. Create the
# database first, then put its connection string here.
#   Local:       mysql://ayah:password@localhost:3306/ayah
#   Production:  mysql://user:password@host:3306/ayah
# If your password has special characters (@ : / etc.), URL-encode them.
# Example:  DATABASE_URL="mysql://ayah:password@localhost:3306/ayah"
DATABASE_URL="mysql://ayah:password@localhost:3306/ayah"


# OPTIONAL  -  Default timezone for brand-new subscribers (IANA name).
# Each subscriber can change their own later with /timezone. This is only
# the starting value. Falls back to UTC if left empty, so set it to your
# main audience's timezone. The bot validates it at boot and refuses to
# start on a typo, so you find out right away.
# Example:  TZ_NAME="Africa/Cairo"   (others: "Europe/London", "Asia/Riyadh")
TZ_NAME="Africa/Cairo"


# OPTIONAL  -  Your numeric Telegram user id. Enables the /admin_* commands
# (health check, manual send) for that one user, in a private chat with the
# bot only. Leave empty to disable all admin commands.
# How to get it: message @userinfobot on Telegram and it replies with your id.
# Example:  ADMIN_TELEGRAM_ID="123456789"
ADMIN_TELEGRAM_ID=""


# OPTIONAL  -  Runtime mode. Set to "production" on a hosted deploy (this
# quietens debug logs and reuses one database pool). Anything else is treated
# as development.
# Example:  NODE_ENV="production"
NODE_ENV="development"


# OPTIONAL  -  HTTP port for the /health endpoint. Defaults to 8080. Many
# hosts inject their own PORT automatically, so you usually leave this empty.
# A blank or invalid value safely falls back to 8080.
# Example:  PORT="8080"
PORT=""
