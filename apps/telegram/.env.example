# =====================================================================
#  Telegram app configuration. Copy to .env:  cp .env.example .env
# =====================================================================

# REQUIRED - Telegram bot token from @BotFather. Treat it like a password.
# Example: BOT_TOKEN="123456789:AAFakeExampleTokenFromBotFather_xxx"
BOT_TOKEN=""

# REQUIRED - MySQL/MariaDB connection, the same database the seed filled.
# Example: DATABASE_URL="mysql://ayah:password@localhost:3306/ayah"
DATABASE_URL="mysql://ayah:password@localhost:3306/ayah"

# OPTIONAL - Default timezone for brand-new subscribers (IANA name). Each
# subscriber can change their own later. Falls back to UTC if unset.
# Example: TZ_NAME="Africa/Cairo"
TZ_NAME="Africa/Cairo"

# OPTIONAL - Your numeric Telegram user id. Unlocks the /admin_* commands
# (health, manual send) for that one user in a private chat only. Leave
# empty to disable all admin commands. Get your id from @userinfobot.
# Example: ADMIN_TELEGRAM_ID="123456789"
ADMIN_TELEGRAM_ID=""

# OPTIONAL - Runtime mode. Set to "production" on a hosted deploy.
NODE_ENV="development"

# OPTIONAL - HTTP port for the /health endpoint. Defaults to 8080.
PORT=""
