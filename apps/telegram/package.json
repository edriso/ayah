{
  "name": "@ayah/telegram",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ayah/core": "workspace:*",
    "@ayah/database": "workspace:*",
    "grammy": "^1.42.0",
    "node-cron": "^4.2.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "cross-env": "^7.0.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.7"
  }
}
