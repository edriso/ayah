# =====================================================================
#  Ayah bot configuration
#
#  Copy this single file to ".env" in this same folder, then fill it in:
#      cp .env.example .env
#
#  Every package and script in the project reads this one root .env, so
#  there is only one file to manage. Each variable below shows what it is,
#  an Example, and any Best practice. The REQUIRED ones come first.
# =====================================================================


# REQUIRED  -  Telegram bot token from @BotFather.
# The bot will not start without it. Treat it like a password.
# How to get it: open @BotFather in Telegram, send /newbot (or /mybots for
# an existing bot), and copy the token it gives you.
# Example:  BOT_TOKEN="123456789:AAFakeExampleTokenFromBotFather_xxx"
BOT_TOKEN=""


# REQUIRED  -  MySQL/MariaDB connection string.
# Create the database first, then put its connection string here. This same
# value is used by the bot, the Prisma CLI, the seed, and the fetch script.
#   Local:       mysql://ayah:password@localhost:3306/ayah
#   Production:  mysql://user:password@host:3306/ayah
# If your password has special characters (@ : / etc.), URL-encode them.
DATABASE_URL="mysql://ayah:password@localhost:3306/ayah"


# OPTIONAL  -  Your numeric Telegram user id. Enables the /admin_* commands
# (health check, manual send) for that one user, in a private chat with the
# bot only. Leave empty to disable all admin commands.
# How to get it: message @userinfobot on Telegram and it replies with your id.
# Example:  ADMIN_TELEGRAM_ID="123456789"
ADMIN_TELEGRAM_ID=""


# OPTIONAL  -  Default timezone for brand-new subscribers (IANA name).
# Each subscriber can change their own later with /timezone; this is only the
# starting value. Falls back to UTC if left empty, so set it to your main
# audience's timezone. The bot validates it at boot and refuses to start on a
# typo, so you find out right away.
# Example:  TZ_NAME="Africa/Cairo"   (others: "Europe/London", "Asia/Riyadh")
TZ_NAME="Africa/Cairo"


# OPTIONAL  -  Runtime mode. This template defaults to "production" because a
# copied .env is normally used to RUN the bot. Production quietens debug logs
# and keeps a single database pool. You do NOT need to change this for local
# work: `pnpm dev` always runs in development mode no matter what is set here.
# Leave it as "production" unless you specifically want `pnpm start` to run in
# development mode.
NODE_ENV="production"


# OPTIONAL  -  HTTP port for the /health endpoint. Defaults to 8080. Many
# hosts inject their own PORT automatically, so you usually leave this empty.
# A blank or invalid value safely falls back to 8080.
# Example:  PORT="8080"
PORT=""


# OPTIONAL  -  Override the Quran text download URL used by `pnpm data:fetch`.
# Leave empty to use the built-in Tanzil Uthmani "Text (with aya numbers)"
# link. Only set this if Tanzil ever changes its URL; the value must point to
# a Tanzil Uthmani text-with-aya-numbers download. Whatever you set is still
# verified (6236 ayat, correct count per surah) before anything is written.
# Example:  QURAN_SOURCE_URL="https://tanzil.net/pub/download/index.php?quranType=uthmani&outType=txt-2&agree=true"
QURAN_SOURCE_URL=""
