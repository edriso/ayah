generator client {
  provider = "prisma-client"
  output   = "../src/database/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// Naming: TS model names are PascalCase singular and TS fields are
// camelCase (idiomatic TypeScript). The @map / @@map directives expose
// snake_case plural tables and snake_case columns in MySQL (the usual SQL
// convention). We do NOT use Prisma enums; short string fields with a
// comment listing the allowed values keep migrations simpler, matching the
// other bots in this folder.

// ─── Quran text (read-only reference data) ──────────────────────────
//
// Surah and Ayah are seeded once from the verified Tanzil Uthmani text and
// are never written to again by the running bot. Keeping the holy text in
// real tables (instead of loose numbers) means a TrackEntry MUST point at
// an ayah that truly exists — the database itself blocks "ayah 300 of a
// 7-ayah surah". A startup check and tests guard the count (6236 ayat).

model Surah {
  // The surah number (1-114) is its natural, stable primary key.
  number     Int    @id
  nameAr     String @db.VarChar(64) // Arabic name, e.g. "البقرة"
  nameEn     String @db.VarChar(64) // Latin transliteration, e.g. "Al-Baqarah"
  revelation String @db.VarChar(16) // "meccan" | "medinan"
  // Number of ayat in this surah. Filled during seeding from the actual
  // ayah rows, so it can never drift from the text.
  ayahCount  Int    @map("ayah_count")

  ayat Ayah[]

  @@map("surahs")
}

model Ayah {
  id            Int    @id @default(autoincrement())
  surahNumber   Int    @map("surah_number")
  numberInSurah Int    @map("number_in_surah")
  text          String @db.Text // Uthmani text, exactly as Tanzil shipped it

  surah   Surah        @relation(fields: [surahNumber], references: [number])
  entries TrackEntry[]

  @@unique([surahNumber, numberInSurah], map: "ayat_surah_number_in_surah_key")
  @@map("ayat")
}

// ─── Tafseer (read-only reference data, one row per edition × ayah) ──
//
// The per-ayah commentary, seeded once from the verified data files and never
// written to again by the bot. A subscriber picks WHICH edition they want
// (Subscriber.tafseerEdition); this table holds them all, keyed by the edition
// code plus the natural (surah, ayah). Modeled like AyahAudio (a natural key,
// no FK to Ayah.id) so seeding needs no ayah-id lookup and a new edition is
// just more rows, not a migration.
//
// For a concise edition the `text` is the full tafseer. For a long edition
// flagged `preview` in the registry (e.g. Ibn Kathir, whose entries run to
// thousands of characters) it is a bounded one-message opening; the rest is a
// "read the full tafseer" link the bot adds (see src/database/reference/
// tafseers.ts and src/core/tafseer.ts). Either way one ayah is one row of text.
model Tafseer {
  // Edition code (see reference/tafseers.ts), e.g. "muyassar", "saadi". Also
  // the value stored in Subscriber.tafseerEdition.
  edition       String @db.VarChar(32)
  surahNumber   Int    @map("surah_number")
  numberInSurah Int    @map("number_in_surah")
  text          String @db.Text

  @@id([edition, surahNumber, numberInSurah])
  @@map("tafseer")
}

// ─── Curriculum ─────────────────────────────────────────────────────

model Track {
  id    Int     @id @default(autoincrement())
  key   String  @unique @db.VarChar(48) // stable code, e.g. "kids-hifz"
  name  String  @db.VarChar(128)
  // When the last entry is reached: true starts again at the first entry,
  // false stops (the subscriber has finished the whole track).
  loops Boolean @default(true)

  entries     TrackEntry[]
  subscribers Subscriber[]

  @@map("tracks")
}

model TrackEntry {
  id       Int @id @default(autoincrement())
  trackId  Int @map("track_id")
  position Int // 0-based order within the track
  ayahId   Int @map("ayah_id")

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  ayah  Ayah  @relation(fields: [ayahId], references: [id])

  currentForSubscribers Subscriber[]  @relation("CurrentEntry")
  deliveries            DeliveryLog[]

  @@unique([trackId, position], map: "track_entries_track_position_key")
  @@unique([trackId, ayahId], map: "track_entries_track_ayah_key")
  @@map("track_entries")
}

// ─── Subscribers ────────────────────────────────────────────────────
//
// One row per person the bot delivers to. (The future channel will be the
// same idea with a different id source; see docs/FUTURE.md.)

model Subscriber {
  id         Int    @id @default(autoincrement())
  telegramId BigInt @unique @map("telegram_id")
  locale     String @default("ar") @db.VarChar(8) // "ar" | "en"
  // IANA timezone, e.g. "Africa/Cairo". Drives the local send time and the
  // local day boundary used for idempotency.
  timezone   String @default("Africa/Cairo") @db.VarChar(64)

  // Daily send time in the subscriber's own local time.
  deliveryHour   Int @default(7) @map("delivery_hour") @db.TinyInt
  deliveryMinute Int @default(0) @map("delivery_minute") @db.TinyInt
  // 7-bit mask of the weekdays the subscriber wants ayat on. Bit 0 is
  // Monday ... bit 6 is Sunday. 127 = every day. See src/core/days.ts.
  activeDays     Int @default(127) @map("active_days")
  // How many PREVIOUS ayat of the same surah to include for review, on top of
  // today's new ayah. 0 = just today's ayah. Validated to 0..20 in the app
  // (MAX_REVIEW_COUNT in src/core). On long surahs the review is split
  // across several messages so it never exceeds Telegram's size limit.
  reviewCount    Int @default(10) @map("review_count")
  // Whether to follow today's ayah with its tafseer as a silent message (no
  // notification sound). On by default; toggled with /tafsir. Skipped
  // automatically if the chosen edition has no seeded tafseer for the ayah.
  tafseerEnabled Boolean @default(true) @map("tafseer_enabled")
  // Which tafseer edition to send: an edition key (see
  // src/database/reference/tafseers.ts). Defaults to التفسير الميسر. Chosen
  // with /tafsir (the source picker).
  tafseerEdition String  @default("muyassar") @map("tafseer_edition") @db.VarChar(32)
  // How to deliver the tafseer: "text" (the commentary inline, the default) or
  // "link" (a short pointer to read it in full on a trusted site). For a long
  // "preview" edition, "text" sends a one-message opening plus the link.
  tafseerFormat  String  @default("text") @map("tafseer_format") @db.VarChar(8)
  // Which reciter's recitation audio to send (silently) after the ayah: a
  // reciter key (see src/database/reference/reciters.ts) or "none" to send no
  // audio. Defaults to the kids teacher style (الحصري المعلِّم). Chosen with
  // /reciter.
  reciter        String  @default("husary-muallim") @map("reciter") @db.VarChar(32)

  trackId Int @map("track_id")
  // The entry the subscriber is currently on. Null means "not started yet";
  // the first delivery sets it to the track's position 0. NOT unique: many
  // subscribers can sit on the same entry.
  currentEntryId Int? @map("current_entry_id")

  // Break: null means active. When set, the bot sends nothing and the
  // position does not advance, so /resume continues exactly where they
  // left off. This is an indefinite break cleared only by /resume.
  pausedAt  DateTime? @map("paused_at")
  // Reachability: null means reachable. Set when Telegram tells us the user
  // blocked the bot (or a send fails with 403); cleared when they message
  // the bot again. Send loops filter `blockedAt IS NULL`.
  blockedAt DateTime? @map("blocked_at")
  // When the very first ayah was delivered (for stats / "member since").
  startedAt DateTime? @map("started_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  track        Track         @relation(fields: [trackId], references: [id])
  currentEntry TrackEntry?   @relation("CurrentEntry", fields: [currentEntryId], references: [id], onDelete: SetNull)
  deliveries   DeliveryLog[]

  @@index([trackId])
  @@index([pausedAt, blockedAt]) // the "who is due" scan filters on these
  @@map("subscribers")
}

// ─── Delivery history + idempotency ─────────────────────────────────

model DeliveryLog {
  id           Int    @id @default(autoincrement())
  subscriberId Int    @map("subscriber_id")
  trackEntryId Int    @map("track_entry_id")
  // The subscriber's LOCAL date the send was meant for ("YYYY-MM-DD").
  // The unique index below turns this into the idempotency lock: a person
  // can get at most one ayah per local day, even if the cron double-fires
  // or catches up after a restart.
  scheduledFor String @map("scheduled_for") @db.VarChar(10)
  status       String @default("sent") @db.VarChar(16) // "sent" | "failed" | "skipped"

  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  trackEntry TrackEntry @relation(fields: [trackEntryId], references: [id])

  @@unique([subscriberId, scheduledFor], map: "delivery_logs_subscriber_date_key")
  @@index([subscriberId, createdAt])
  @@map("delivery_logs")
}

// ─── Recitation audio cache (Telegram file_ids) ─────────────────────
//
// We never store the audio bytes (one reciter for the whole Quran is ~1 GB).
// The first time an ayah's audio is sent for a given reciter, Telegram fetches
// it from the CDN and hands back a file_id; we store that here and reuse it on
// every later send (instant, no re-fetch). Keyed by (surah, ayah, reciter), so
// each reciter caches independently. Fills lazily as ayat are delivered.

model AyahAudio {
  surahNumber   Int    @map("surah_number")
  numberInSurah Int    @map("number_in_surah")
  reciter       String @db.VarChar(32) // reciter key (see reference/reciters.ts)
  fileId        String @map("file_id") @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([surahNumber, numberInSurah, reciter])
  @@map("ayah_audio")
}
