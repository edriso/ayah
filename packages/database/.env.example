# =====================================================================
#  Database configuration (used by the Prisma CLI and the seed/fetch
#  scripts in this package).
#
#  Copy this file to ".env" in the same folder:
#      cp .env.example .env
# =====================================================================


# REQUIRED  -  MySQL/MariaDB connection string. Used by every Prisma CLI
# command (generate, migrate, db push, studio) and by the seed script.
# Create the database first, then fill this in. Use the SAME value here and
# in apps/telegram/.env so the bot and the tools talk to one database.
#   Local:       mysql://ayah:password@localhost:3306/ayah
#   Production:  mysql://user:password@host:3306/ayah
# If your password has special characters (@ : / etc.), URL-encode them.
DATABASE_URL="mysql://ayah:password@localhost:3306/ayah"


# OPTIONAL  -  Override the Quran text download URL used by `pnpm data:fetch`.
# Leave empty to use the built-in Tanzil Uthmani "Text (with aya numbers)"
# link. Only set this if Tanzil changes its URL; the value must point to a
# Tanzil Uthmani text-with-aya-numbers download. Whatever you set is still
# verified (6236 ayat, correct count per surah) before anything is written.
# Example:  QURAN_SOURCE_URL="https://tanzil.net/pub/download/index.php?quranType=uthmani&outType=txt-2&agree=true"
QURAN_SOURCE_URL=""
