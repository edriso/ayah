# Database connection used by the Prisma CLI (generate, migrate, studio)
# and by the seed script.
#
# MySQL / MariaDB. Create the database first, then fill this in.
#   Local:      mysql://ayah:password@localhost:3306/ayah
#   Production: mysql://user:password@host:3306/ayah
DATABASE_URL="mysql://ayah:password@localhost:3306/ayah"
